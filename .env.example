# Ports
API_PORT=3001
BACKEND_PORT=8000
FRONTEND_PORT=3000

# RabbitMQ credentials
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Introspector API database credentials
INTROSPECTER_API_DB_USER=introspecter_user
INTROSPECTER_API_DB_PASSWORD=introspecter_pass
INTROSPECTER_API_DB_NAME=introspecter_db

# Introspector backend database credentials
INTROSPECTER_BACKEND_DB_USER=backend_user
INTROSPECTER_BACKEND_DB_PASSWORD=backend_password
INTROSPECTER_BACKEND_DB_NAME=introspecter_backend

# Project paths and URLs
BACKEND_URL=http://introspecter-backend:8000
HOST_PROJECT_PATH=~/Desktop/introspecter

# External API keys (replace with your own)
KSCOPE_API_KEY=your_kscope_api_key_here
KSCOPE_API_BASE=your_kscope_api_base_here
OPENAI_API_KEY=your_openai_api_key_here
TOGETHER_API_KEY=your_together_api_key_here