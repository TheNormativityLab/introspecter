{
  "name": "Introspecter Full Stack",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "introspecter-backend",
  "workspaceFolder": "/workspace",
  "runServices": [
    "introspecter-backend",
    "introspecter-frontend",
    "introspecter-api",
    "introspecter-rabbitmq",
    "introspecter-celery-worker",
    "introspecter-celery-beat",
    "introspecter-flower",
    "introspecter-postgres-api",
    "introspecter-postgres-backend",
    "pgadmin"
  ],
  "forwardPorts": [3000, 3001, 8000, 5173, 5555, 15672, 5050, 5433, 5434],
  "portsAttributes": {
    "3001": {
      "label": "API",
      "onAutoForward": "notify"
    },
    "3000": {
      "label": "Frontend",
      "onAutoForward": "notify"
    },
    "5555": {
      "label": "Flower",
      "onAutoForward": "silent"
    },
    "15672": {
      "label": "RabbitMQ Management",
      "onAutoForward": "silent"
    },
    "5050": {
      "label": "pgAdmin",
      "onAutoForward": "silent"
    }
  },
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[python]": {
          "editor.defaultFormatter": "ms-python.python"
        },
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "typescript.tsdk": "/workspace/frontend/node_modules/typescript/lib",
        "files.watcherExclude": {
          "**/node_modules/**": true,
          "**/__pycache__/**": true
        }
      }
    }
  },
  "remoteUser": "root",
  "remoteEnv": {
    "SHELL": "/usr/bin/zsh"
  },
  "postCreateCommand": "echo '🚀 All services started! Access your code at: /workspace'"
}
