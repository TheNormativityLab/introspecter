{
  "name": "Introspecter Full Stack",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "introspecter-backend",
  "workspaceFolder": "/workspace",
  "runServices": [],
  "forwardPorts": [3000, 3001, 8000, 5555, 15672, 5050],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "overrideCommand": false
}