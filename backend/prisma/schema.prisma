generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LlmConfig {
  id          Int      @id @default(autoincrement())
  modelName   String   @map("model_name")
  model       String
  apiBase     String?  @map("api_base")
  timeout     Int      @default(300)
  numRetries  Int      @default(5) @map("num_retries")
  rpm         Int?
  topP        Float?   @map("top_p")
  maxTokens   Int?     @map("max_tokens")
  temperature Float?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  debates     Debate[] @relation("DebateToLlmConfig")

  @@unique([modelName, model])
  @@map("llm_configs")
}

model Debate {
  id              Int         @id @default(autoincrement())

  /// wandb run.id (stable, global)
  experimentId    String      @unique @map("experiment_id")

  seed            Int?
  datasetName     String?     @map("dataset_name")
  status          String      @default("completed")

  performanceData Json?       @map("performance_data")
  resultData      Json?       @map("result_data")
  wandbMetadata   Json?       @map("wandb_metadata")

  processedAt     DateTime    @map("processed_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  llmConfigs      LlmConfig[] @relation("DebateToLlmConfig")

  @@map("debates")
}

model ArgumentativeRun {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runName       String   @map("run_name")
  sourceFile    String   @map("source_file")
  debaterModel  String?  @map("debater_model")
  judgeModel    String?  @map("judge_model")
  numRounds     Int?     @map("num_rounds")
  metrics       Json?
  config        Json?
  createdAt     DateTime @default(now()) @map("created_at")

  runQuestions  ArgumentativeRunQuestion[]

  @@unique([runName])
  @@map("argumentative_runs")
}

model ArgumentativeQuestion {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionText    String   @unique @map("question_text")
  storyTitle      String?  @map("story_title")
  storyText       String?  @map("story_text")
  correctAnswer   String   @default("") @map("correct_answer")
  incorrectAnswer String   @default("") @map("incorrect_answer")
  createdAt       DateTime @default(now()) @map("created_at")

  runQuestions    ArgumentativeRunQuestion[]

  @@map("argumentative_questions")
}

model ArgumentativeRunQuestion {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId           String   @map("run_id") @db.Uuid
  questionId      String   @map("question_id") @db.Uuid
  questionIndex   Int?     @map("question_index")
  correctPosition String?  @map("correct_position")
  judgment        String?
  isCorrect       Boolean? @map("is_correct")
  cost            Float?
  createdAt       DateTime @default(now()) @map("created_at")

  run             ArgumentativeRun     @relation(fields: [runId], references: [id])
  question        ArgumentativeQuestion @relation(fields: [questionId], references: [id])
  rounds          ArgumentativeRound[]

  @@unique([runId, questionId])
  @@map("argumentative_run_questions")
}

model ArgumentativeRound {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runQuestionId       String   @map("run_question_id") @db.Uuid
  roundNumber         Int      @map("round_number")
  /// 'round' | 'response'
  roundType           String   @map("round_type")
  correctArgument     String?  @map("correct_argument")
  incorrectArgument   String?  @map("incorrect_argument")
  crossExaminerText   String?  @map("cross_examiner_text")
  judgeText           String?  @map("judge_text")
  createdAt           DateTime @default(now()) @map("created_at")

  runQuestion         ArgumentativeRunQuestion @relation(fields: [runQuestionId], references: [id])

  @@unique([runQuestionId, roundNumber, roundType])
  @@map("argumentative_rounds")
}

model AgentConversation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messages  Json     @default("[]")
  metadata  Json     @default("{}")
  plots     Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("agent_conversations")
}