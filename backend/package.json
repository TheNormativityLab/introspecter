{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "pnpm exec prisma generate && pnpm exec prisma db push",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "db:generate": "pnpm exec prisma generate",
    "db:push": "pnpm exec prisma db push",
    "db:migrate": "pnpm exec prisma migrate dev",
    "db:studio": "pnpm exec prisma studio",
    "db:reset": "pnpm exec prisma migrate reset",
    "migrate-data": "node src/scripts/db_manager.js"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "prisma": "^6.11.1",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "commander": "^14.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "4.16.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "ts-node-dev": "^2.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "nodemon": "^3.0.2"
  }
}